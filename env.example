# =================================================================
# InsightLLM Backend Environment Configuration
# Copy this file to .env and fill in your actual values
#
# NOTE:
# Not all variables are required for every deployment.
# Only variables referenced by the running code must be set.
# =================================================================


# ==============================================================
# SUPABASE CORE CONFIGURATION
# ==============================================================

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SERVICE_KEY=your-service-role-key

SUPABASE_SCHEMA=public
SUPABASE_TABLE=documents
SUPABASE_STORAGE_BUCKET=annotated-pdfs
SIGNED_URL_TTL_SECONDS=3600


# ==============================================================
# AUTHENTICATION & SECURITY
# ==============================================================

JWT_SECRET_KEY=your-long-random-jwt-secret


# ==============================================================
# LLM PROVIDER CONFIGURATION
# ==============================================================

LLM_PROVIDER=groq
# Options: "groq", "openai", "xai"

CHATBOT_LLM_MODEL=llama-3.3-70b-versatile
MCQ_LLM_MODEL=llama-3.3-70b-versatile


# ==============================================================
# AI PROVIDER API KEYS
# ==============================================================

GROQ_API_KEY=your-groq-api-key
OPENAI_API_KEY=your-openai-api-key
XAI_API_KEY=your-xai-grok-api-key
GOOGLE_CLOUD_KEY=your-google-cloud-api-key


# ==============================================================
# VECTOR SEARCH & EMBEDDINGS
# ==============================================================

EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
TOP_K=8


# ==============================================================
# AZURE DOCUMENT INTELLIGENCE (OCR / PDF ANALYSIS)
# ==============================================================

AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_API_KEY=your-azure-ocr-key


# ==============================================================
# RAG PIPELINE SAFETY & OPTIMIZATION
# ==============================================================

ENABLE_RERANKER=false
ENABLE_PII_FILTER=true
ENABLE_INJECTION_GUARD=true
ENABLE_CACHE=true
CACHE_TTL_S=600


# ==============================================================
# RUNTIME LIMITS & SAFETY GUARDS
# ==============================================================

MAX_ITERATIONS=4
MAX_TOKENS=4096
MAX_TIME_S=30


# ==============================================================
# OCR TIMEOUT SETTINGS
# ==============================================================

OCR_PER_PAGE_TIMEOUT=120.0
OCR_OVERALL_TIMEOUT=600.0


# ==============================================================
# OCR RETRY & BACKOFF STRATEGY
# ==============================================================

OCR_MAX_RETRIES=3
OCR_RETRY_BASE_DELAY=1.0
OCR_RETRY_MAX_DELAY=60.0
OCR_RETRY_JITTER_RANGE=0.2

OCR_RATE_LIMIT_BASE_DELAY=5.0
OCR_RATE_LIMIT_MAX_DELAY=300.0


# ==============================================================
# OCR PERFORMANCE & RESOURCE MANAGEMENT
# ==============================================================

OCR_CONCURRENT_PAGES=2
OCR_MIN_CONCURRENT=1
OCR_MAX_CONCURRENT=4
OCR_BATCH_SIZE=5

OCR_MAX_IMAGE_DIMENSION=2500
OCR_DPI=150


# ==============================================================
# OCR BATCH FAILURE CONTROL
# ==============================================================

OCR_BATCH_FAILURE_THRESHOLD=0.5


# ==============================================================
# OCR RATE LIMIT SAFEGUARDS
# ==============================================================

OCR_RATE_LIMIT_THRESHOLD=2
OCR_RATE_LIMIT_COOLDOWN=60


# ==============================================================
# ADAPTIVE CONCURRENCY CONTROL
# ==============================================================

OCR_ADAPTIVE_CONCURRENCY_ENABLED=true
OCR_ADAPTIVE_MIN_CONCURRENCY=1
OCR_ADAPTIVE_MAX_CONCURRENCY=4
OCR_ADAPTIVE_LATENCY_THRESHOLD_MS=90000
OCR_ADAPTIVE_STABLE_BATCHES=2


# ==============================================================
# OCR IMAGE OPTIMIZATION
# ==============================================================

OCR_IMAGE_OPTIMIZATION_ENABLED=true
OCR_IMAGE_MAX_DIMENSION=2048
OCR_IMAGE_MIN_DIMENSION_FOR_OPTIMIZATION=1500


# ==============================================================
# STREAMING & RAG MODES (Example-only / Optional)
# ==============================================================

ENABLE_STREAMING=true
STREAMING_TIMEOUT=60

USE_ADAPTIVE_RAG=true
USE_MULTI_STEP_RAG=true


# ==============================================================
# PERFORMANCE & LOGGING (Deployment-specific)
# ==============================================================

WORKERS=2
LOG_LEVEL=INFO
ENABLE_LOGGING=true
MAX_UPLOAD_MB=20


# ==============================================================
# TELEMETRY (Optional)
# ==============================================================

LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=insightLLM_production
LANGSMITH_TRACING=false


# ==============================================================
# ENVIRONMENT & CORS
# ==============================================================

NODE_ENV=production
CORS_ORIGINS=https://your-frontend-domain.com,https://www.your-frontend-domain.com


# ==============================================================
# REDIS (Optional)
# ==============================================================

# REDIS_URL=redis://redis:6379


# ==============================================================
# DOMAIN & DEPLOYMENT
# ==============================================================

DOMAIN=your-domain.com
FRONTEND_DOMAIN=https://your-frontend-domain.com
