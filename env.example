# ==============================================================
# SUPABASE CORE CONFIGURATION
# Backend services, authentication, database, and storage
# ==============================================================

SUPABASE_URL=
# Base URL for the Supabase project (REST, Auth, Storage, RPC)

SUPABASE_KEY=
# Public (anon) API key — safe for client-side usage with RLS enabled

SUPABASE_SERVICE_ROLE_KEY=
# Server-only key with full database access (bypasses RLS)
# NEVER expose this to frontend code

SUPABASE_SERVICE_KEY=
# Alias for service role key (used by backend services / workers)

SUPABASE_SCHEMA=public
# Default Postgres schema for application tables

SUPABASE_TABLE=documents
# Primary table used for document storage / vector indexing

SUPABASE_STORAGE_BUCKET=annotated-pdfs
# Supabase Storage bucket for OCR outputs, annotations, or processed PDFs

SIGNED_URL_TTL_SECONDS=3600
# Expiry time (seconds) for signed download URLs


# ==============================================================
# AUTHENTICATION & SECURITY
# ==============================================================

JWT_SECRET_KEY=
# Secret used for signing/verifying JWTs
# Must remain private and consistent across deployments


# ==============================================================
# LLM PROVIDER CONFIGURATION
# Controls which AI backend is active
# ==============================================================

# LLM_PROVIDER={"groq","openai","xai"}
# Defines the active LLM provider (must match enabled API key)

CHATBOT_LLM_MODEL=llama-3.3-70b-versatile
# Model used for conversational chatbot responses

MCQ_LLM_MODEL=llama-3.3-70b-versatile
# Model used for MCQ generation / structured reasoning tasks


# ==============================================================
# AI PROVIDER API KEYS
# Enable only what you actively use
# ==============================================================

GROQ_API_KEY=
# Groq API key for ultra-fast LLM inference

OPENAI_API_KEY=
# OpenAI API key (optional / alternate provider)

Grok_API=
# xAI (Grok) API key

Google_cloud_key=
# Google Cloud API key (used for auxiliary services if enabled)


# ==============================================================
# VECTOR SEARCH & EMBEDDINGS
# ==============================================================

# VECTOR_BACKEND={"supabase","weaviate"}
# Selects the vector database backend

EMBEDDING_MODEL_NAME="BAAI/bge-small-en-v1.5"
# Sentence embedding model used for semantic search & RAG

TOP_K=8
# Number of top vector matches retrieved per query


# ==============================================================
# AZURE DOCUMENT INTELLIGENCE (OCR / PDF ANALYSIS)
# ==============================================================

AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://evalbotpaid.cognitiveservices.azure.com/
# Azure Cognitive Services endpoint for document analysis

AZURE_DOCUMENT_INTELLIGENCE_API_KEY=
# API key for Azure Document Intelligence


# ==============================================================
# RAG PIPELINE SAFETY & OPTIMIZATION FLAGS
# ==============================================================

ENABLE_RERANKER=false
# Enables secondary reranking stage for higher-quality retrieval

ENABLE_PII_FILTER=true
# Automatically detects and masks sensitive personal data

ENABLE_INJECTION_GUARD=true
# Protects against prompt-injection attacks in user inputs

ENABLE_CACHE=true
# Enables response caching to reduce LLM cost and latency

CACHE_TTL_S=600
# Cache expiration time in seconds


# ==============================================================
# RUNTIME LIMITS & SAFETY GUARDS
# ==============================================================

MAX_ITERATIONS=4
# Maximum reasoning / tool-calling iterations per request

MAX_TOKENS=4096
# Upper bound for LLM token generation

MAX_TIME_S=30
# Hard execution timeout (seconds) per request


# ==================================================================
# OCR TIMEOUT SETTINGS
# Defines hard execution limits to prevent runaway OCR processes
# ==================================================================

OCR_PER_PAGE_TIMEOUT=120.0        # Maximum processing time (seconds) per individual page
OCR_OVERALL_TIMEOUT=600.0         # Global timeout (seconds) for the entire OCR job


# ==================================================================
# OCR RETRY & BACKOFF STRATEGY
# Gracefully handles transient failures and external API throttling
# ==================================================================

OCR_MAX_RETRIES=3                 # Retry attempts per page before marking as failed
OCR_RETRY_BASE_DELAY=1.0          # Initial backoff delay (seconds) for retry attempts
OCR_RETRY_MAX_DELAY=60.0          # Maximum retry delay (seconds)
OCR_RETRY_JITTER_RANGE=0.2        # Random jitter (0.0–1.0) to prevent synchronized retries

OCR_RATE_LIMIT_BASE_DELAY=5.0     # Initial delay (seconds) after hitting rate limits
OCR_RATE_LIMIT_MAX_DELAY=300.0    # Maximum cooldown (seconds) for rate-limit recovery


# ==================================================================
# OCR PERFORMANCE & RESOURCE MANAGEMENT
# Tunes throughput while protecting CPU, memory, and I/O stability
# ==================================================================

OCR_CONCURRENT_PAGES=2            # Pages processed in parallel (static baseline)
OCR_MIN_CONCURRENT=1              # Lower bound for allowed concurrency
OCR_MAX_CONCURRENT=4              # Upper bound for allowed concurrency
OCR_BATCH_SIZE=5                  # Number of pages grouped per OCR execution batch

OCR_MAX_IMAGE_DIMENSION=2500      # Max image width/height (pixels) before downscaling
OCR_DPI=150                       # DPI used during preprocessing (accuracy vs speed tradeoff)

# ==================================================================
# OCR BATCH FAILURE CONTROL
# Detects systemic failures early and prevents wasted processing
# ==================================================================

OCR_BATCH_FAILURE_THRESHOLD=0.5
# Fraction (0.0–1.0) of failed pages within a batch required to
# mark the entire batch as failed and abort further processing
#
# Example:
# 0.5  → Fail batch if ≥50% of pages fail
# 0.25 → Fail fast on widespread issues (aggressive)
# 0.75 → More tolerant of partial failures (lenient)



# ==================================================================
# OCR RATE LIMIT SAFEGUARDS
# Applies circuit-breaking behavior under repeated throttling
# ==================================================================

OCR_RATE_LIMIT_THRESHOLD=2        # Consecutive rate-limit events before cooldown engages
OCR_RATE_LIMIT_COOLDOWN=60        # Cooldown period (seconds) after threshold is exceeded


# ==================================================================
# ADAPTIVE CONCURRENCY CONTROL
# Dynamically adjusts parallelism based on observed OCR latency
# ==================================================================

OCR_ADAPTIVE_CONCURRENCY_ENABLED=true
# Enables automatic tuning of OCR concurrency at runtime

OCR_ADAPTIVE_MIN_CONCURRENCY=1
# Minimum concurrency level when system is under high latency

OCR_ADAPTIVE_MAX_CONCURRENCY=4
# Maximum concurrency level when system latency is stable

OCR_ADAPTIVE_LATENCY_THRESHOLD_MS=90000
# Latency threshold (milliseconds) beyond which concurrency is reduced

OCR_ADAPTIVE_STABLE_BATCHES=2
# Number of consecutive stable batches required before scaling concurrency up

# ==================================================================
# OCR IMAGE OPTIMIZATION
# Preprocesses images to balance OCR accuracy, speed, and memory use
# ==================================================================

OCR_IMAGE_OPTIMIZATION_ENABLED=true
# Enables automatic image resizing before OCR execution

OCR_IMAGE_MAX_DIMENSION=2048
# Target maximum width/height (pixels) after optimization
# Images larger than this will be downscaled proportionally

OCR_IMAGE_MIN_DIMENSION_FOR_OPTIMIZATION=1500
# Minimum image dimension (pixels) required to trigger optimization
# Prevents unnecessary rescaling of already-small or low-resolution images

DEBUG_SECTIONS=true

SAVE_TEST_FILES=false
# Set to true in local development to save OCR test files (JSON/TXT) to Tests folder
# Set to false in production (Railway) to prevent test file creation

MAX_UPLOAD_MB=20

LOG_LEVEL=INFO
ENABLE_LOGGING=true